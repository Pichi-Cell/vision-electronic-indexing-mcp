{
  "mcp": {
    "vision-inventory": {
      "type": "local",
      "command": [
        "python3",
        "/path/to/vision-electronic-indexing-mcp/vision_inventory_mcp.py"
      ],
      "enabled": true,
      "env": {
        "CLOUDFLARE_ACCOUNT_ID": "your_cloudflare_account_id",
        "CLOUDFLARE_AUTH_TOKEN": "your_cloudflare_workers_ai_token"
      }
    }
  }
}
